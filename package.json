{
  "name": "@cupix-sdk/siteview-sdk",
  "description": "CupixWorks SiteView SDK for embedding",
  "version": "0.1.0",
  "scripts": {
    "build": "webpack --mode=production --node-env=production",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --node-env=production",
    "watch": "webpack --watch",
    "serve": "webpack serve --config ./webpack-dev.config.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/umd/siteview-sdk.min.js",
  "license": "MIT",
  "files": [
    "dist",
    "!**/node_modules"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cupix-io/siteview-sdk"
  },
  "keywords": [
    "cupix",
    "cupixworks",
    "siteview",
    "headless",
    "siteview-sdk",
    "digital-twin",
    "360 Panorama",
    "360 Image",
    "Equirectangular",
    "BIM"
  ],
  "devDependencies": {
    "@babel/core": "^7.19.6",
    "@babel/preset-env": "^7.19.4",
    "@webpack-cli/generators": "^2.5.0",
    "babel-loader": "^9.0.1",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "prettier": "^2.7.1",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.11.1"
  }
}
